import flet as ft
from flet_audio import Audio


def main(page: ft.Page):
    page.title = "Music Player"
    page.bgcolor = "Blue"

    songs = [
        "Music/se.vienen.cosas.buenas.mp3",
        "Music/Ricky.Bobby.mp3",
        "Music/Inglés.en.miami.mp3",
        "Music/GAS.mp3",
        "Music/POR.SI.MAÑANA.NO.ESTOY.mp3",
    ]

    names = [
        "Se Vienen Cosas: rawayana",
        "Ricky Bobby: Eladio Carrión",
        "Ingles en Miami: rawayana",
        "GAS: Yk It's Junaa",
        "Por Si Mañana: Omar Courtz",
    ]

    i = 0

    audio = Audio(src=songs[i], autoplay=False)
    page.services.append(audio)

    title = ft.Text(names[i], size=30, color="white")

    def change_song():
        audio.src = songs[i]
        title.value = names[i]
        page.update()

    async def play(e):
        await audio.play()

    async def pause(e):
        await audio.pause()

    async def next_song(e):
        nonlocal i
        i += 1
        if i >= len(songs):
            i = 0
        change_song()
        await audio.play()

    async def prev_song(e):
        nonlocal i
        i -= 1
        if i < 0:
            i = len(songs) - 1
        change_song()
        await audio.play()

    page.add(
        ft.Column(
            [
                title,
                ft.Row(
                    [
                        ft.ElevatedButton("Play", on_click=play),
                        ft.ElevatedButton("Pause", on_click=pause),
                        ft.ElevatedButton("Next", on_click=next_song),
                        ft.ElevatedButton("Back", on_click=prev_song),
                    ],
                    alignment=ft.MainAxisAlignment.CENTER,
                ),
            ],
            alignment=ft.MainAxisAlignment.CENTER,
            horizontal_alignment=ft.CrossAxisAlignment.CENTER,
        )
    )


ft.app(target=main, assets_dir="Assets")